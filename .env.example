# Application
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/kgtech_file_processing

# Redis (6380 = Docker Compose + portable Windows Redis; use 6379 on Linux/macOS native Redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# BullMQ
BULLMQ_PREFIX=bull
QUEUE_NAME=file-processing
WORKER_CONCURRENCY=5
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_DELAY_MS=1000
JOB_FAILURE_RATE=0.2
JOB_MIN_PROCESSING_MS=5000
JOB_MAX_PROCESSING_MS=10000
MAX_FILE_SIZE_BYTES=104857600

# Auth (set AUTH_ENABLED=true to require JWT)
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
JWT_SECRET=dev-jwt-secret-change-me-in-production
JWT_EXPIRES_IN=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# AWS S3 (optional — required for POST /upload-url)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_UPLOAD_PREFIX=uploads
AWS_S3_PRESIGNED_URL_EXPIRES_IN=3600
